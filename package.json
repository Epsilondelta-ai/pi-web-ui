{
  "name": "pi-web-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Astro prototype for operating pi from a browser.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "backend": "go run ./backend/cmd/pi-web-server",
    "backend:mock": "go run ./backend/cmd/pi-web-server --mock",
    "backend:test": "go test ./...",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "bun run test && bun run backend:test && bun run build && bun run build-storybook"
  },
  "dependencies": {
    "astro": "6.3.3"
  },
  "devDependencies": {
    "@storybook-astro/framework": "1.2.0",
    "@storybook/addon-docs": "10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "jsdom": "29.1.1",
    "storybook": "10.4.0",
    "vitest": "4.1.6"
  }
}
